<UserControl x:Class="PiwotOBSDeck.UI.SceneNodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PiwotOBSDeck.UI"
             mc:Ignorable="d" >
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Professional Arrow Style -->
        <Style x:Key="ExpanderArrowStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Width="16" Height="16">
                            <Path x:Name="Arrow" Data="M 0,0 L 4,4 L 0,8" Stroke="Gray" StrokeThickness="2" 
                              HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </Path.RenderTransform>
                            </Path>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <StackPanel Orientation="Horizontal">
            <!-- Expansion Toggle -->
            <ToggleButton x:Name="button_toggle" Style="{StaticResource ExpanderArrowStyle}"
                  IsChecked="False"
                  Visibility="Collapsed"
                  Click="ToggleButton_Click"/>
            <Border x:Name="border" Width="16" Visibility="Collapsed"/>
            <Image x:Name="image_icon" Width="16" Height="16" Margin="4,0"/>
            <TextBlock x:Name="text_name" Text="Name..." VerticalAlignment="Center" Margin="4,0"/>
        </StackPanel>
    </Grid>
</UserControl>
